{
  "cleanUrls": true,
  "functions": {
    "api/chat.js": { "maxDuration": 30 },
    "api/tts.js": { "maxDuration": 30 },
    "api/transcribe.js": { "maxDuration": 30 },
    "api/try-on.js": { "maxDuration": 60 }
  },
  "rewrites": [
    {
      "source": "/api/chat",
      "destination": "/api/chat"
    },
    {
      "source": "/api/tts",
      "destination": "/api/tts"
    },
    {
      "source": "/",
      "destination": "/thesis.html"
    },
    {
      "source": "/marketplace",
      "destination": "/marketplace.html"
    },
    {
      "source": "/interventions",
      "destination": "/interventions.html"
    },
    {
      "source": "/product/:id",
      "destination": "/product.html"
    }
  ]
}
